{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "vite.config.ts",
        "scripts/**/*.ts"
    ]
}